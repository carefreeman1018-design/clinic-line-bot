PORT=3000

# LINE Developers > Messaging API
LINE_CHANNEL_SECRET=你的_LINE_Channel_Secret
LINE_CHANNEL_ACCESS_TOKEN=你的_LINE_Channel_Access_Token
LINE_ADMIN_USER_IDS=

# Optional. If empty, the bot replies with a simple template from the knowledge base.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional. Supabase conversation memory.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CONVERSATION_TABLE=line_conversation_messages
MAX_CONVERSATION_MESSAGES_PER_USER=40
SUPABASE_SETTINGS_TABLE=bot_settings
SUPABASE_KNOWLEDGE_TABLE=knowledge_chunks
SUPABASE_KNOWLEDGE_MATCH_RPC=match_knowledge_chunks
VECTOR_KNOWLEDGE_ENABLED=true
VECTOR_KNOWLEDGE_MATCH_COUNT=6
VECTOR_KNOWLEDGE_MIN_SIMILARITY=0.25
KNOWLEDGE_DELETE_BATCH_SIZE=100

# Optional. LINE VOOM announcement sync.
LINE_VOOM_SYNC_ENABLED=true
LINE_VOOM_SYNC_TIME=03:00
LINE_VOOM_URL=https://linevoom.line.me/user/_dSPK5oF-CvsqFetilXhgKCCZmDAXN2oLLLhsP7U
LINE_VOOM_OUTPUT=data/line-voom-announcements.md
LINE_VOOM_KEYWORDS=休診,停診,公休,休假,正常看診,照常看診,門診,連假
